name: Docs

on:
  push:
    branches: [main]
    paths:
      - 'docs/**'
      - 'mkdocs.yml'
      - 'pyproject.toml'
      - 'uv.lock'
      - '.github/workflows/docs.yml'
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: pages
  cancel-in-progress: false

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: astral-sh/setup-uv@v5
      - uses: actions/setup-python@v5
        with:
          python-version: '3.12'
      # __SOCIAL_CI__  (init-docs-site.sh --social inserts the Cairo/Pango + cache steps here)
      - run: uv sync --extra docs
      - run: uv run mkdocs build --strict
      - uses: actions/upload-pages-artifact@v3
        with:
          path: site

  deploy:
    needs: build
    runs-on: ubuntu-latest
    environment:
      name: github-pages
      url: ${{ steps.deployment.outputs.page_url }}
    steps:
      - id: deployment
        uses: actions/deploy-pages@v5
        # NOTE: the GitHub Pages backend intermittently returns "Deployment
        # failed, try again later." or queues for a while. No input mitigates
        # it — `timeout` is capped at 10m (larger values are clamped + warn)
        # and `error_count` only covers polling errors, not that final status.
        # The only fix is to re-run the failed job: gh run rerun <id> --failed
